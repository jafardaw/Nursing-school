# تفعيل ضغط Brotli
AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css application/javascript application/json application/wasm

# ترويسات COOP و COEP لتفعيل تعدد الخيوط
Header always set Cross-Origin-Opener-Policy "same-origin"
Header always set Cross-Origin-Embedder-Policy "require-corp"

# تمكين HTTP/3 (إذا كان السيرفر يدعمه)
Header always set Alt-Svc 'h3=":443"; ma=86400'

# تخزين مؤقت للملفات الثابتة
<FilesMatch "\.(js|wasm|avif|css)$">
    Header set Cache-Control "max-age=31536000, immutable"
</FilesMatch>

<FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>